# === TOKENS ===
# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=YOUR_DISCORD_TOKEN
# UnbelievaBoat API token (get from dashboard: https://unbelievaboat.com/dashboard)
UNBELIEVABOAT_TOKEN=YOUR_UNBELIEVABOAT_TOKEN
# UnbelievaBoat API base URL
UNBELIEVABOAT_URL=https://unbelievaboat.com/api/v1

# === DISCORD IDs ===
# Bot application ID from Discord Developer Portal
CLIENT_ID=YOUR_CLIENT_ID
# Main server (guild) ID (right-click server -> Copy ID)
GUILD_ID=YOUR_GUILD_ID
# Default channel ID for bot commands
CHANNEL_ID=YOUR_CHANNEL_ID

# === ROLE IDS ===
# Role ID for staff/high-ranking members (right-click role -> Copy ID)
STAFFSUS_ID=YOUR_STAFF_ROLE_ID

# === LOG CHANNEL IDS ===
# Channel for member-facing patrol log reports
LOG_PATROLI_CHANNEL_ID=YOUR_CHANNEL_ID
# Channel for admin patrol log reports (with approve/reject buttons)
LOG_PATROLI_ADMIN_CHANNEL_ID=YOUR_CHANNEL_ID
# Channel for promotion log embeds
LOG_PROMOTION_CHANNEL_ID=YOUR_CHANNEL_ID
# Channel for bot logs
LOG_BOT_CHANNEL_ID=YOUR_CHANNEL_ID

# === PATROLI POST ===
# Channel where the patroli hub panel is posted (via /patroli-post)
PATROLI_CHANNEL_ID=YOUR_CHANNEL_ID
# Message ID (leave empty, will be auto-set on first run)
PATROLI_MESSAGE_ID=

# === PROMOTION POST ===
# Channel where the promotion hub panel is posted (via /promotion-post)
PROMOTION_CHANNEL_ID=YOUR_CHANNEL_ID
# Message ID (leave empty, will be auto-set on first run)
PROMOTION_MESSAGE_ID=

# === ACHIEVEMENT CENTER ===
# Channel ID for the achievement center board
ACHIEVEMENT_CENTER_CHANNEL_ID=YOUR_CHANNEL_ID
# Message ID (leave empty, will be auto-set on first run)
ACHIEVEMENT_CENTER_MESSAGE_ID=

# === HALL OF HONOR ===
# Channel ID for the hall of honor main panel
HALL_OF_HONOR_CHANNEL_ID=YOUR_CHANNEL_ID
# Channel ID for hall of honor admin approval requests (with buttons)
HALL_OF_HONOR_APPROVAL_CHANNEL_ID=YOUR_CHANNEL_ID
# Channel ID for hall of honor member-facing submissions
HALL_OF_HONOR_MEMBER_CHANNEL_ID=YOUR_CHANNEL_ID
# Message ID (leave empty, will be auto-set on first run)
HALL_OF_HONOR_MESSAGE_ID=
